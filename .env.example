# انسخ إلى Render → Environment → ملف أو متغيرات منفصلة (لا ترفع القيم إلى Git)
PORT=4000

# Cloudflare — مطلوب لرفع الفيديو/الصور من التطبيق (التطبيق لا يحمل التوكن)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# لوحة الإدارة v2
ADMIN_EMAIL=admin@nomas.sa
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
# قديم — للـ admin.html فقط
ADMIN_SECRET=

# محلي: اتركه فارغاً (يستخدم backend/data). على Render: /var/data (قرص دائم)
# DATA_DIR=/var/data

# Amazon SNS — SMS لرمز التحقق (App Store). عند التفعيل يُخفى devCode تلقائياً.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
# Transactional = OTP | Promotional = تسويق
AWS_SNS_SMS_TYPE=Transactional
# اختياري — قد لا يعمل لجميع الدول
# AWS_SNS_SENDER_ID=NOMAS

# للتطوير المحلي فقط (بدون SNS): true يعرض الرمز على الشاشة
OTP_EXPOSE_CODE=true
