# انسخ إلى Render → Environment → ملف أو متغيرات منفصلة (لا ترفع القيم إلى Git)
PORT=4000

# Cloudflare — مطلوب لرفع الفيديو/الصور من التطبيق (التطبيق لا يحمل التوكن)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# اختياري
ADMIN_SECRET=

# محلي: اتركه فارغاً (يستخدم backend/data). على Render: /var/data (قرص دائم)
# DATA_DIR=/var/data
