# انسخ إلى Render → Environment → ملف أو متغيرات منفصلة (لا ترفع القيم إلى Git)
PORT=4000

# Cloudflare — مطلوب لرفع الفيديو/الصور من التطبيق (التطبيق لا يحمل التوكن)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# لوحة الإدارة v2
ADMIN_EMAIL=admin@nomas.sa
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
# قديم — للـ admin.html فقط
ADMIN_SECRET=

# محلي: اتركه فارغاً (يستخدم backend/data). على Render: /var/data (قرص دائم)
# DATA_DIR=/var/data

# SMS OTP — taqnyat (موصى به للسعودية) | sns | auto
SMS_PROVIDER=taqnyat

# تقنيات Taqnyat — https://portal.taqnyat.sa → المطورين → التطبيقات
TAQNYAT_BEARER_TOKEN=
TAQNYAT_SENDER=NOMAS

# Amazon SNS — بديل/احتياطي
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SNS_SMS_TYPE=Transactional
# AWS_SNS_SENDER_ID=NOMAS

# للتطوير المحلي فقط (بدون SMS): true يعرض الرمز على الشاشة
OTP_EXPOSE_CODE=true

# OTP ثابت لأرقام مطوّرين — لا يُرسل SMS ولا يمس Taqnyat
# OTP_DEV_PHONES=+966500756705
# OTP_DEV_CODE=123456
# OTP_DEV_EXPOSE_CODE=false
